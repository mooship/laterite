---
import Layout from "../components/Layout.astro";
import PostMeta from "../components/PostMeta.astro";
import { config } from "../config";
import { filterPublished, getAllPosts, sortByDateDesc } from "../utils/posts";
import { slugifyPath } from "../utils/slugify";

const base = config.baseUrl;

const sortedPosts = sortByDateDesc(filterPublished(getAllPosts()));
---

<Layout title="Dispatches | The Red Soil" description="All dispatches from The Red Soil">
  <div class="dispatches-page">
    <header class="dispatches-header">
      <h1 class="dispatches-title">Dispatches</h1>
      <p class="dispatches-description">
        Critical eco-socialist and decolonial analysis from Africa and the Global South — exposing
        the systems that exploit both people and the planet.
      </p>
      <hr class="page-rule" />
    </header>

    {
      sortedPosts.length > 0 ? (
        <div class="posts-list">
          {sortedPosts.map((post: any) => (
            <article class="post-item">
              <h2 class="post-title">
                <a href={`${base}dispatches/${slugifyPath(post.file)}`} data-astro-prefetch>
                  {post.frontmatter.title}
                </a>
              </h2>

              <PostMeta
                datePublished={post.frontmatter.datePublished}
                author={post.frontmatter.author}
                minutesRead={post.frontmatter.minutesRead}
              />

              {post.frontmatter.excerpt && <p class="post-excerpt">{post.frontmatter.excerpt}</p>}

              {post.frontmatter.categories && (
                <div class="post-categories">
                  {post.frontmatter.categories.map((category: string) => (
                    <span class="post-category">{category}</span>
                  ))}
                </div>
              )}

              <a
                href={`${base}dispatches/${slugifyPath(post.file)}`}
                data-astro-prefetch
                class="read-more"
              >
                Read More <span aria-hidden="true">→</span>
              </a>
            </article>
          ))}
        </div>
      ) : (
        <div class="no-posts">
          <p>
            No posts available yet. Start writing by creating files in{" "}
            <code>src/pages/dispatches/</code>
          </p>
        </div>
      )
    }
  </div>
</Layout>

<style>
  .dispatches-page {
    max-width: var(--content-width);
    margin: 0 auto;
  }

  .dispatches-header {
    text-align: center;
    margin-bottom: calc(var(--grid-unit) * 8);
  }

  .dispatches-title {
    font-family: var(--font-heading-primary);
    font-size: 3.5rem;
    font-weight: 900;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1.1;
    margin-bottom: calc(var(--grid-unit) * 3);
  }

  .dispatches-description {
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin-bottom: calc(var(--grid-unit) * 4);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: calc(var(--grid-unit) * 6);
  }

  .post-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: calc(var(--grid-unit));
    margin-bottom: calc(var(--grid-unit) * 2);
  }

  .post-meta > * {
    display: inline-flex;
    align-items: center;
    gap: calc(var(--grid-unit) / 2);
  }

  @media (min-width: 769px) {
    .post-meta > *:not(:last-child)::after {
      content: "•";
      margin-left: calc(var(--grid-unit) / 2);
      color: var(--color-text-muted);
    }
  }

  .post-date,
  .post-reading-time {
    font-variant-numeric: tabular-nums;
  }

  .no-posts {
    text-align: center;
    padding: calc(var(--grid-unit) * 6);
    color: var(--color-text-muted);
    font-style: italic;
  }

  .no-posts code {
    background-color: var(--color-surface);
    padding: 2px 4px;
    border-radius: 3px;
    font-family: var(--font-mono);
  }

  @media (max-width: 768px) {
    .dispatches-title {
      font-size: 2.5rem;
    }

    .dispatches-description {
      font-size: 1.125rem;
    }

    .post-meta {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
